{
    "name": "storepackage/warehouse-core",
    "description": "Framework-agnostic warehouse automation core with inventory valuation, reservations, movements and audit trail.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "warehouse",
        "inventory",
        "stock",
        "fifo",
        "lifo",
        "average-cost",
        "composer-package"
    ],
    "authors": [
        {
            "name": "Store Package Team"
        }
    ],
    "require": {
        "php": ">=5.6 <8.2"
    },
    "suggest": {
        "ext-pdo": "Required to use the reference PDO-based database adapter.",
        "ext-pdo_sqlite": "Optional for running the SQLite-backed DB adapter smoke check."
    },
    "require-dev": {
        "ext-dom": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-mbstring": "*",
        "ext-tokenizer": "*",
        "ext-xmlwriter": "*",
        "phpunit/phpunit": "^5.7 || ^9.6"
    },
    "autoload": {
        "psr-4": {
            "StorePackage\\WarehouseCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StorePackage\\WarehouseCore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "@php tools/lint.php",
        "test": "@test:phpunit",
        "test:phpunit": "@php tools/run-phpunit.php",
        "test:legacy": "@test:phpunit",
        "test:legacy:docker": "bash tools/run-legacy-tests-docker.sh",
        "test:modern": "@test:phpunit",
        "test:db-smoke": "@php tools/run-db-adapter-smoke.php",
        "test:db:mysql:docker": "bash tools/run-mysql-verification-docker.sh test",
        "test:db:pgsql:docker": "bash tools/run-postgres-verification-docker.sh test",
        "test:smoke": "@php tools/run-smoke-tests.php",
        "verify": [
            "@lint",
            "@test:smoke"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
